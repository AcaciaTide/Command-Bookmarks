{
	"schemaVersion": 1,
	"id": "commandbookmark",
	"version": "${version}",
	"name": "Command Bookmarks",
	"description": " A client-side Fabric mod that lets you bookmark and execute frequently used commands and chat messages with a single click. ",
	"authors": [
		"AcaciaTide"
	],
	"contact": {
		"sources": "https://github.com/AcaciaTide/Command-Bookmarks"
	},
	"license": "MIT",
	"icon": "assets/commandbookmark/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"acaciatide.commandbookmark.CommandBookmarkClient"
		]
	},
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": ">=26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}